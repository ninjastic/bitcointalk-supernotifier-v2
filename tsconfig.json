{
  "compilerOptions": {
    "target": "ESNext",
    "lib": [
      "ESNext"
    ],
    "emitDecoratorMetadata": true,
    "experimentalDecorators": true,
    "rootDir": "./src",
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "paths": {
      "*": ["./src/*"],
      "##/*": ["./src/*"]
    },
    "resolveJsonModule": true,
    "types": ["node", "jest"],
    "strictPropertyInitialization": false,
    "outDir": "./dist",
    "sourceMap": true,
    "esModuleInterop": true,
    "skipLibCheck": true
  },
  "include": ["src/**/*.ts", "scripts/*.ts"],
  "exclude": ["node_modules"]
}
